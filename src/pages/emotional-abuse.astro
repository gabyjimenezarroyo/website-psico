---
import CTASection from "@components/CTASection.astro";
import InfoCards from "@components/InfoCards.astro";
import PageHero from "@components/PageHero.astro";
import SelfTest from "@components/react/SelfTest";
import BaseLayout from "@layouts/BaseLayout.astro";

const signs = [
  { title: "Dudas de vos", text: "Te preguntas si exageras, si recordas mal o si sos demasiado sensible." },
  { title: "Culpa constante", text: "Sentis que todo conflicto termina siendo tu responsabilidad." },
  { title: "Miedo a hablar", text: "Medis cada palabra para evitar enojo, silencio o castigo emocional." },
  { title: "Aislamiento", text: "Te cuesta contar lo que pasa porque temes no ser comprendida." },
  { title: "Agotamiento", text: "Vivis en alerta, con ansiedad, confusion o cansancio emocional." },
  { title: "Perdida de identidad", text: "Tus necesidades, gustos y limites empiezan a quedar en segundo plano." },
];
const faq = [
  ["¿Que es abuso emocional?", "Es un patron de control, desvalorizacion, manipulacion o intimidacion que afecta tu seguridad psicologica y tu autonomia."],
  ["¿El gaslighting es abuso emocional?", "Puede serlo cuando la otra persona niega, distorsiona o minimiza repetidamente tu percepcion para controlar la narrativa."],
  ["¿Como empieza la recuperacion?", "Con seguridad, claridad, red de apoyo y un proceso terapeutico que te ayude a reconstruir confianza interna."],
];
---

<BaseLayout title="Abuso emocional: senales, sintomas y recuperacion" description="Guia sobre abuso emocional: senales, sintomas, gaslighting, proceso de recuperacion y test orientativo.">
  <PageHero eyebrow="Abuso emocional" title="Abuso emocional: cuando amar empieza a doler y confundirte" description="El abuso emocional puede ser silencioso, gradual y dificil de explicar. Nombrarlo es una forma de volver a confiar en vos." secondaryLabel="Hacer self-test" secondaryHref="#self-test" />
  <section class="section-pad bg-white"><div class="container-premium"><InfoCards items={signs} /></div></section>
  <section class="section-pad">
    <div class="container-premium grid gap-10 lg:grid-cols-2">
      <div>
        <p class="eyebrow">Recovery process</p>
        <h2 class="mt-4 font-display text-5xl font-bold text-ink">De la confusion a la claridad</h2>
        <p class="mt-5 leading-8 text-ink/70">La recuperacion suele incluir reconocer patrones, estabilizar el sistema nervioso, reconstruir limites, procesar culpa y recuperar autonomia emocional.</p>
      </div>
      <div class="grid gap-4">
        {["Nombrar lo vivido", "Crear seguridad", "Reconstruir limites", "Practicar decisiones libres"].map((step, index) => (
          <div class="rounded-soft bg-white p-5 shadow-soft"><span class="font-bold text-secondary">0{index + 1}</span><p class="mt-2 font-display text-2xl font-bold text-ink">{step}</p></div>
        ))}
      </div>
    </div>
  </section>
  <section id="self-test" class="section-pad bg-white"><div class="container-premium"><SelfTest type="abuse" client:load /></div></section>
  <section class="section-pad">
    <div class="container-premium max-w-3xl">
      <p class="eyebrow">FAQ</p>
      <h2 class="mt-4 font-display text-5xl font-bold text-ink">Preguntas frecuentes</h2>
      <div class="mt-8 grid gap-4">{faq.map(([q, a]) => <article class="rounded-soft bg-white p-6 shadow-soft"><h3 class="font-display text-2xl font-bold text-ink">{q}</h3><p class="mt-3 leading-7 text-ink/68">{a}</p></article>)}</div>
    </div>
  </section>
  <CTASection title="Recuperar tu voz empieza con un espacio seguro." />
</BaseLayout>
