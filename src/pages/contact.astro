---
import PageHero from "@components/PageHero.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@utils/site";

const facebookUrl = "https://www.facebook.com/bienestarprana";
const wazeUrl = "https://www.waze.com/ul?ll=9.949372792676236%2C-84.06381999858034&navigate=yes";
---

<BaseLayout title="Contacto" description="Agendá una consulta con Gaby Jiménez por WhatsApp, Instagram o Facebook.">
  <PageHero eyebrow="Contacto" title="Agendá un espacio para empezar" description="Podemos coordinar una primera consulta para entender tu situación, responder dudas y definir el proceso más adecuado para vos." image="/images/g_contact.jpg" imageAlt="Gaby Jiménez en su espacio de consulta" showActions={false} />
  <section class="section-pad bg-white">
    <div class="container-premium grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="contact-card">
        <p class="eyebrow">Canales directos</p>
        <h2>Elegí cómo querés contactarme</h2>
        <p>
          Podés escribir por redes, coordinar por WhatsApp o abrir la ubicación para llegar al consultorio.
        </p>
        <div class="contact-actions">
          <a href={site.whatsapp} class="contact-action contact-action-primary">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L4 20.3l1.1-4a8.4 8.4 0 1 1 15.4-4.5Z" />
              <path d="M9.2 8.2c.2-.4.4-.5.7-.5h.5c.2 0 .4 0 .6.4l.7 1.7c.1.3.1.5-.1.7l-.4.5c-.1.1-.2.3 0 .5.4.8 1.1 1.5 2 2 .2.1.4.1.5-.1l.6-.7c.2-.2.4-.2.7-.1l1.7.8c.3.1.4.4.4.6 0 .7-.5 1.6-1.2 1.8-.7.3-2.6.1-4.5-1.3-2-1.5-3.2-3.5-3.3-4.9 0-.6.2-1.1.5-1.4Z" />
            </svg>
            WhatsApp
          </a>
          <a href={site.instagram} class="contact-action">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="4" y="4" width="16" height="16" rx="5" />
              <circle cx="12" cy="12" r="3.5" />
              <path d="M17.3 6.8h.01" />
            </svg>
            Instagram
          </a>
          <a href={facebookUrl} class="contact-action">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14 8h2V4h-2.6C10.7 4 9 5.8 9 8.5V11H7v4h2v5h4v-5h2.5l.5-4h-3V8.8c0-.5.3-.8 1-.8Z" />
            </svg>
            Facebook
          </a>
          <a href={wazeUrl} class="contact-action">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 21s7-4.4 7-11a7 7 0 1 0-14 0c0 6.6 7 11 7 11Z" />
              <circle cx="12" cy="10" r="2.8" />
            </svg>
            Waze
          </a>
        </div>
      </div>
      <aside class="grid gap-5">
        <div class="schedule-card">
          <div class="schedule-heading">
            <h2>Horario de atención</h2>
          </div>
          <div class="schedule-grid">
            <article class="schedule-block">
              <div class="schedule-mode">
                <span aria-hidden="true">👥</span>
                <p>Presencial</p>
              </div>
              <div class="schedule-days">
                <span>Lunes</span>
                <span>Miércoles</span>
                <span>Sábados</span>
              </div>
              <strong>9am a 9pm</strong>
            </article>
            <article class="schedule-block schedule-block-virtual">
              <div class="schedule-mode">
                <span aria-hidden="true">💻</span>
                <p>Virtual</p>
              </div>
              <div class="schedule-days">
                <span>Lunes a sábado</span>
              </div>
              <strong>9am a 9pm</strong>
            </article>
          </div>
        </div>
        <div class="overflow-hidden rounded-soft bg-soft shadow-soft">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3929.814668830493!2d-84.06381999858034!3d9.949372792676236!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e487d3651e0d%3A0x33f940211943f356!2sClinica%20Santa%20Ana!5e0!3m2!1sen!2scr!4v1781667937561!5m2!1sen!2scr"
            width="600"
            height="450"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Clínica Santa Ana"
            class="min-h-80 w-full"
          ></iframe>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-card {
    display: grid;
    align-content: center;
    border-radius: 2rem;
    background:
      radial-gradient(circle at 86% 16%, rgba(141, 224, 216, 0.24), transparent 15rem),
      linear-gradient(145deg, #f8fbfa, #ffffff);
    padding: clamp(1.75rem, 4vw, 2.5rem);
    box-shadow: 0 24px 70px rgba(26, 26, 26, 0.08);
  }

  .contact-card h2 {
    margin: 1rem 0 0;
    max-width: 31rem;
    font-family: "Playfair Display", serif;
    font-size: clamp(2.5rem, 5vw, 4.7rem);
    line-height: 0.98;
    color: #1a1a1a;
  }

  .contact-card > p:not(.eyebrow) {
    margin: 1.2rem 0 0;
    max-width: 34rem;
    color: rgba(26, 26, 26, 0.68);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .contact-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .contact-action {
    display: inline-flex;
    min-height: 4rem;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border: 1px solid rgba(47, 109, 106, 0.14);
    border-radius: 999px;
    background: #ffffff;
    color: #2f6d6a;
    font-size: 0.95rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(47, 109, 106, 0.08);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .contact-action:hover,
  .contact-action:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(78, 202, 194, 0.7);
    background: #f7fffe;
    outline: none;
  }

  .contact-action-primary {
    background: #2f6d6a;
    color: #ffffff;
  }

  .contact-action-primary:hover,
  .contact-action-primary:focus-visible {
    background: #285f5c;
  }

  .contact-action svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .contact-action[href*="facebook"] svg {
    fill: currentColor;
    stroke: none;
  }

  .schedule-card {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    background:
      radial-gradient(circle at 100% 0%, rgba(141, 224, 216, 0.24), transparent 12rem),
      linear-gradient(145deg, #ffffff, #f8fbfa);
    padding: 1.75rem;
    box-shadow: 0 24px 70px rgba(26, 26, 26, 0.08);
  }

  .schedule-heading h2 {
    margin: 0;
    font-family: "Playfair Display", serif;
    font-size: clamp(2rem, 4vw, 2.55rem);
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1;
  }

  .schedule-grid {
    display: grid;
    gap: 1rem;
    margin-top: 1.35rem;
  }

  .schedule-block {
    display: grid;
    gap: 1rem;
    border: 1px solid rgba(47, 109, 106, 0.1);
    border-radius: 1.35rem;
    background: rgba(255, 255, 255, 0.84);
    padding: 1rem;
    box-shadow: 0 14px 35px rgba(47, 109, 106, 0.07);
  }

  .schedule-block-virtual {
    background: rgba(47, 109, 106, 0.06);
  }

  .schedule-mode {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .schedule-mode span {
    display: grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border-radius: 999px;
    background: rgba(216, 137, 148, 0.18);
    font-size: 1.1rem;
  }

  .schedule-mode p {
    margin: 0;
    color: #2f6d6a;
    font-weight: 900;
  }

  .schedule-days {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .schedule-days span {
    border-radius: 999px;
    background: #ffffff;
    padding: 0.45rem 0.7rem;
    color: rgba(26, 26, 26, 0.68);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .schedule-block strong {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    border-radius: 999px;
    background: #2f6d6a;
    padding: 0.55rem 0.85rem;
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 900;
  }

  @media (max-width: 640px) {
    .contact-actions {
      grid-template-columns: 1fr;
    }
  }
</style>
