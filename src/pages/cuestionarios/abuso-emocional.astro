---
import CTASection from "@components/CTASection.astro";
import PageHero from "@components/PageHero.astro";
import QuestionnaireThermometer from "@components/QuestionnaireThermometer.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const questions = [
  "¿Con frecuencia terminas emocionalmente agotada después de interactuar con esta persona?",
  "¿Sientes alivio cuando la otra persona está de buen humor porque disminuye la tensión en la relación?",
  "¿Has notado que tu nivel de estrés aumentó significativamente desde que comenzó esta relación?",
  "¿Pasas mucho tiempo anticipando posibles reacciones o conflictos antes de que ocurran?",
  "¿Sientes que rara vez puedes relajarte completamente dentro de la relación?",
  "¿Tu tranquilidad emocional parece depender del estado emocional de la otra persona?",
  "¿Has comenzado a sentirte más insegura, ansiosa o nerviosa en tu vida cotidiana?",
  "¿Te resulta difícil recordar la última vez que te sentiste verdaderamente tranquila dentro de la relación?",
  "¿Notas que tu energía emocional se consume intentando mantener la estabilidad de la relación?",
  "¿Sientes que la relación afecta negativamente tu bienestar psicológico general?",
];

const resultBands = [
  {
    min: 0,
    max: 2,
    level: "Riesgo bajo",
    summary: "Riesgo bajo",
    thermometerLabel: "Bienestar emocional preservado",
    detail:
      "No aparecen indicadores importantes de desgaste emocional asociado a una relación dañina. La relación parece contribuir de forma saludable a tu bienestar.",
    color: "#16803c",
    accent: "#10b981",
    soft: "#ecfdf5",
  },
  {
    min: 3,
    max: 5,
    level: "Atención",
    summary: "Atención",
    thermometerLabel: "Señales de desgaste",
    detail:
      "Existen señales que merecen observación. Algunas dinámicas podrían estar generando tensión o desgaste emocional.",
    color: "#a16207",
    accent: "#facc15",
    soft: "#fefce8",
  },
  {
    min: 6,
    max: 8,
    level: "Riesgo elevado",
    summary: "Riesgo elevado",
    thermometerLabel: "Impacto emocional importante",
    detail:
      "Se observan múltiples indicadores de afectación emocional persistente. Comprender estas dinámicas puede ayudarte a recuperar bienestar y claridad.",
    color: "#c05621",
    accent: "#fb923c",
    soft: "#fff7ed",
  },
  {
    min: 9,
    max: 10,
    level: "Riesgo alto",
    summary: "Riesgo alto",
    thermometerLabel: "Necesitas apoyo y claridad",
    detail:
      "Tus respuestas reflejan un impacto emocional significativo asociado a la relación. Buscar apoyo profesional podría ayudarte a comprender mejor lo que estás viviendo.",
    color: "#c53030",
    accent: "#ef4444",
    soft: "#fef2f2",
  },
];

const disclaimer =
  "Este resultado no constituye un diagnóstico psicológico. Su objetivo es ayudarte a identificar señales que merecen atención y reflexión.";
---

<BaseLayout
  title="Cuestionario de abuso emocional"
  description="Cuestionario interactivo para identificar señales de desgaste emocional asociado a una relación dañina."
>
  <PageHero
    eyebrow="Cuestionarios"
    title="¿Podrías estar viviendo abuso emocional?"
    description="El abuso emocional ocurre cuando una relación, en lugar de hacerte sentir segura y en paz,
comienza a llenarte de miedo, confusión, culpa o inseguridad. No siempre hay gritos o violencia
física; muchas veces aparece a través del control, la manipulación, la desvalorización o conductas
que van afectando poco a poco tu bienestar.
Este cuestionario te ayudará a identificar algunas señales de alerta y reflexionar sobre cómo esa
relación podría estar impactando tu salud emocional."
    primaryLabel="Responder cuestionario"
    primaryHref="#cuestionario"
    secondaryLabel="Agendar consulta"
    secondaryHref="/contact"
  />

  <section id="cuestionario" class="section-pad bg-white">
    <div class="container-premium">
      <QuestionnaireThermometer
        id="emotional-abuse-questionnaire"
        eyebrow="Termómetro emocional"
        title="Cuestionario: ¿Podrías estar viviendo abuso emocional?"
        intro="Responde Sí o No a cada afirmación. Al completar las 10 preguntas, verás tu resultado en un termómetro emocional por colores."
        questions={questions}
        resultBands={resultBands}
        disclaimer={disclaimer}
      />
    </div>
  </section>

  <CTASection title="No tenés que interpretar estas señales sola." />
</BaseLayout>
