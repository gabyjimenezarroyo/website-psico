---
interface Item {
  title: string;
  text: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
  {
    items.map((item) => (
      <article class="rounded-soft border border-secondary/10 bg-white p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:shadow-lift">
        <div class="mb-5 grid size-12 place-items-center rounded-2xl bg-primary/15 text-xl font-bold text-secondary">·</div>
        <h3 class="font-display text-2xl font-bold text-ink">{item.title}</h3>
        <p class="mt-3 leading-7 text-ink/68">{item.text}</p>
      </article>
    ))
  }
</div>
