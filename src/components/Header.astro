---
import { navItems, site } from "@utils/site";

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-white/85 backdrop-blur-xl">
  <nav class="container-premium flex min-h-20 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3" aria-label="Ir al inicio">
      <span class="grid size-11 place-items-center rounded-full bg-primary/20 text-lg font-bold text-secondary">GJ</span>
      <span class="leading-tight">
        <span class="block font-display text-xl font-bold text-ink">{site.professionalName}</span>
        <span class="block text-xs font-semibold uppercase tracking-[0.16em] text-secondary/80">{site.title}</span>
      </span>
    </a>
    <div class="hidden items-center gap-5 lg:flex">
      {
        navItems.map((item) =>
          "children" in item ? (
            <div class="group relative">
              <button
                type="button"
                class:list={[
                  "flex items-center gap-1 text-sm font-semibold transition hover:text-secondary",
                  item.children.some((child) => current === child.href) ? "text-secondary" : "text-ink/68",
                ]}
                aria-haspopup="true"
              >
                {item.label}
                <span aria-hidden="true" class="text-xs leading-none">▾</span>
              </button>
              <div class="invisible absolute left-1/2 top-full w-56 -translate-x-1/2 pt-4 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <div class="rounded-2xl border border-black/5 bg-white p-2 shadow-soft">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        "block rounded-xl px-4 py-3 text-sm font-semibold transition hover:bg-primary/10 hover:text-secondary",
                        current === child.href ? "bg-primary/10 text-secondary" : "text-ink/68",
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                "text-sm font-semibold transition hover:text-secondary",
                current === item.href ? "text-secondary" : "text-ink/68",
              ]}
            >
              {item.label}
            </a>
          ),
        )
      }
    </div>
    <a
      href="/contact"
      class="hidden rounded-full bg-secondary px-5 py-3 text-sm font-bold text-white shadow-lift transition hover:-translate-y-0.5 md:inline-flex"
    >
      Agendar
    </a>
    <button
      type="button"
      class="mobile-menu-toggle inline-flex size-11 items-center justify-center rounded-full border border-black/10 text-ink transition hover:border-secondary hover:text-secondary lg:hidden"
      aria-controls="mobile-navigation"
      aria-expanded="false"
      aria-label="Abrir menú de navegación"
    >
      <span class="sr-only">Abrir menú</span>
      <span class="flex flex-col gap-1.5" aria-hidden="true">
        <span class="block h-0.5 w-5 rounded-full bg-current"></span>
        <span class="block h-0.5 w-5 rounded-full bg-current"></span>
        <span class="block h-0.5 w-5 rounded-full bg-current"></span>
      </span>
    </button>
  </nav>
  <div
    id="mobile-navigation"
    class="hidden max-h-[calc(100vh-5rem)] overflow-y-auto overscroll-y-contain border-t border-black/5 bg-white [-webkit-overflow-scrolling:touch] [max-height:calc(100dvh-5rem)] lg:hidden"
  >
    <div class="container-premium space-y-2 py-4">
      {
        navItems.map((item) =>
          "children" in item ? (
            <details class="group rounded-2xl border border-black/5 bg-soft/70">
              <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-bold text-ink/78 marker:hidden">
                {item.label}
                <span class="text-xs transition group-open:rotate-180" aria-hidden="true">▾</span>
              </summary>
              <div class="space-y-1 px-2 pb-2">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      "block rounded-xl px-4 py-3 text-sm font-semibold transition hover:bg-primary/10 hover:text-secondary",
                      current === child.href ? "bg-primary/10 text-secondary" : "text-ink/68",
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class:list={[
                "block rounded-2xl px-4 py-3 text-sm font-bold transition hover:bg-primary/10 hover:text-secondary",
                current === item.href ? "bg-primary/10 text-secondary" : "text-ink/78",
              ]}
            >
              {item.label}
            </a>
          ),
        )
      }
      <a
        href="/contact"
        class="mt-3 inline-flex w-full justify-center rounded-full bg-secondary px-5 py-3 text-sm font-bold text-white shadow-lift"
      >
        Agendar
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const menuToggle = document.querySelector(".mobile-menu-toggle");
  const mobileNavigation = document.querySelector("#mobile-navigation");

  if (menuToggle && mobileNavigation) {
    const setMenuOpen = (isOpen) => {
      mobileNavigation.classList.toggle("hidden", !isOpen);
      menuToggle.setAttribute("aria-expanded", String(isOpen));
      menuToggle.setAttribute("aria-label", isOpen ? "Cerrar menú de navegación" : "Abrir menú de navegación");
    };

    menuToggle.addEventListener("click", () => {
      setMenuOpen(mobileNavigation.classList.contains("hidden"));
    });

    mobileNavigation.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setMenuOpen(false));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setMenuOpen(false);
      }
    });
  }
</script>
