---
interface ResultBand {
  min: number;
  max: number;
  level: string;
  summary: string;
  detail: string;
  thermometerLabel: string;
  color: string;
  accent: string;
  soft: string;
}

interface Props {
  id: string;
  eyebrow?: string;
  title: string;
  intro: string;
  questions: string[];
  resultBands: ResultBand[];
  disclaimer: string;
  contactHref?: string;
  contactLabel?: string;
}

const {
  id,
  eyebrow = "Cuestionario interactivo",
  title,
  intro,
  questions,
  resultBands,
  disclaimer,
  contactHref = "/contact",
  contactLabel = "Agendar una consulta",
} = Astro.props;

const orderedBands = [...resultBands].sort((a, b) => b.max - a.max);
const gradientStops = orderedBands
  .map((band, index) => {
    const position = orderedBands.length === 1 ? 0 : (index / (orderedBands.length - 1)) * 100;
    return `${band.accent} ${position}%`;
  })
  .join(", ");
const thermometerGradient = `linear-gradient(180deg, ${gradientStops})`;
---

<section
  id={id}
  class="overflow-hidden rounded-soft border border-secondary/10 bg-white shadow-soft"
  data-questionnaire-thermometer
  data-total={questions.length}
>
  <div class="grid gap-0 lg:grid-cols-[1fr_19rem]">
    <div class="p-5 md:p-8">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="mt-3 font-display text-3xl font-bold text-ink md:text-5xl">{title}</h2>
      <p class="mt-4 max-w-3xl leading-8 text-ink/70">{intro}</p>
    </div>

    <aside class="border-t border-black/10 bg-soft p-5 md:p-6 lg:border-l lg:border-t-0">
      <div class="flex items-center justify-between gap-4">
        <span class="text-sm font-bold text-ink/70">Avance</span>
        <span class="text-sm font-bold text-secondary"><span data-answered-count>0</span>/{questions.length}</span>
      </div>
      <div class="mt-4 h-3 overflow-hidden rounded-full bg-black/10">
        <div class="h-full rounded-full bg-secondary transition-all duration-300" style="width: 0%" data-progress-bar></div>
      </div>
      <div class="mt-5 rounded-2xl border border-black/10 bg-white p-4">
        <p class="text-sm font-semibold leading-6 text-ink/64" data-missing-text>
          Faltan {questions.length} respuestas.
        </p>
      </div>
    </aside>
  </div>

  <form class="grid gap-4 border-t border-black/5 bg-soft p-5 md:p-8" data-questionnaire-form>
    {
      questions.map((question, index) => (
        <article class="rounded-2xl border border-black/10 bg-white p-4 shadow-[0_10px_30px_rgba(26,26,26,0.04)] md:p-5">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <p class="max-w-3xl text-sm font-semibold leading-7 text-ink/78 md:text-base">
              <span class="mr-2 font-bold text-secondary">{index + 1}.</span>
              {question}
            </p>
            <fieldset class="grid grid-cols-2 gap-2 md:w-44" aria-label={`Respuesta ${index + 1}`}>
              {
                [
                  ["yes", "Sí"],
                  ["no", "No"],
                ].map(([value, label]) => {
                  const inputId = `${id}-${index}-${value}`;

                  return (
                    <label for={inputId} class="cursor-pointer">
                      <input
                        id={inputId}
                        type="radio"
                        name={`${id}-${index}`}
                        value={value}
                        class="peer sr-only"
                        data-answer
                      />
                      <span class="grid min-h-11 place-items-center rounded-full border border-black/10 bg-soft px-4 text-sm font-bold text-ink/68 transition hover:border-primary hover:text-secondary peer-checked:border-secondary peer-checked:bg-secondary peer-checked:text-white peer-checked:shadow-lift">
                        {label}
                      </span>
                    </label>
                  );
                })
              }
            </fieldset>
          </div>
        </article>
      ))
    }
  </form>

  <div class="flex flex-wrap items-center gap-3 border-t border-black/5 bg-white p-5 md:p-8">
    <button
      type="button"
      class="min-h-12 rounded-full bg-secondary px-6 text-sm font-bold text-white shadow-lift transition hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:bg-ink/25 disabled:shadow-none disabled:hover:translate-y-0"
      data-show-result
      disabled
    >
      Ver resultado
    </button>
    <button
      type="button"
      class="min-h-12 rounded-full border border-black/10 bg-white px-6 text-sm font-bold text-ink/68 transition hover:border-primary hover:text-secondary"
      data-reset
    >
      Reiniciar
    </button>
  </div>

  <div class="hidden border-t border-black/5 bg-white p-5 md:p-8" data-result-panel>
    <div class="grid overflow-hidden rounded-soft border border-black/10 bg-white shadow-soft lg:grid-cols-[18rem_1fr]">
      <div class="relative overflow-hidden bg-[#edf8f6] p-6 text-secondary">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_20%,rgba(78,202,194,0.26),transparent_34%),linear-gradient(160deg,rgba(255,255,255,0.92),rgba(141,224,216,0.16)_58%,rgba(47,109,106,0.08))]"></div>
        <div class="relative">
          <p class="text-center text-sm font-bold uppercase tracking-[0.12em] text-secondary/80">Termómetro emocional</p>

          <div class="mt-8 flex justify-center">
            <div class="relative h-[25rem] w-32">
              <div class="absolute left-1/2 top-2 h-[20rem] w-24 -translate-x-1/2 rounded-full bg-primary/25 blur-3xl"></div>
              <div
                class="absolute left-1/2 top-0 h-[18rem] w-14 -translate-x-1/2 overflow-hidden rounded-full border border-white/90 bg-white/75 p-1.5 shadow-[inset_0_1px_14px_rgba(255,255,255,0.75),0_24px_60px_rgba(47,109,106,0.18)]"
              >
                <div
                  class="relative h-full overflow-hidden rounded-full"
                  style={`background: ${thermometerGradient};`}
                >
                  <div class="absolute inset-0 bg-white/48 backdrop-saturate-150"></div>
                  <div
                    class="absolute inset-x-0 bottom-0 rounded-t-full transition-all duration-700 ease-out"
                    style="height: 8%; background: #10b981"
                    data-thermometer-fill
                  ></div>
                  <div class="absolute left-3 top-6 h-44 w-3 rounded-full bg-white/48 blur-[1px]"></div>
                </div>
              </div>
              <div
                class="absolute left-1/2 top-[15.85rem] size-28 -translate-x-1/2 rounded-full border border-white/90 bg-emerald-400 p-3 shadow-[inset_0_10px_22px_rgba(255,255,255,0.35),0_28px_65px_rgba(47,109,106,0.28)] transition-colors duration-700"
                data-thermometer-bulb
              >
                <div class="size-full rounded-full bg-white/16"></div>
              </div>
              <div
                class="absolute left-[6.15rem] top-4 h-[16.25rem] w-px bg-secondary/22"
                data-thermometer-track
              >
                <div
                  class="absolute left-1/2 size-4 -translate-x-1/2 rounded-full border-[3px] border-white bg-emerald-400 shadow-[0_0_0_7px_rgba(47,109,106,0.10)] transition-all duration-700"
                  style="bottom: 0%"
                  data-thermometer-marker
                ></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="p-6 md:p-8" data-result-content>
        <div class="inline-flex rounded-full border px-4 py-2 text-sm font-bold" data-result-level></div>
        <h3 class="mt-4 font-display text-3xl font-bold md:text-5xl" data-result-summary></h3>
        <p class="mt-3 text-base font-bold leading-7" data-result-thermometer-label></p>
        <p class="mt-5 max-w-3xl leading-8 text-ink/72" data-result-detail></p>
        <p class="mt-6 rounded-2xl border border-black/10 bg-white/75 p-5 text-sm font-semibold leading-7 text-ink/64">
          {disclaimer}
        </p>
        <a
          href={contactHref}
          class="mt-6 inline-flex min-h-11 items-center rounded-full bg-secondary px-5 text-sm font-bold text-white shadow-lift transition hover:-translate-y-0.5"
        >
          {contactLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ id, resultBands }}>
  const root = document.getElementById(id);
  const bands = resultBands;

  if (root) {
    const total = Number(root.dataset.total);
    const form = root.querySelector("[data-questionnaire-form]");
    const answeredCount = root.querySelector("[data-answered-count]");
    const progressBar = root.querySelector("[data-progress-bar]");
    const missingText = root.querySelector("[data-missing-text]");
    const showResultButton = root.querySelector("[data-show-result]");
    const resetButton = root.querySelector("[data-reset]");
    const resultPanel = root.querySelector("[data-result-panel]");
    const thermometerFill = root.querySelector("[data-thermometer-fill]");
    const thermometerBulb = root.querySelector("[data-thermometer-bulb]");
    const thermometerMarker = root.querySelector("[data-thermometer-marker]");
    const resultContent = root.querySelector("[data-result-content]");
    const resultLevel = root.querySelector("[data-result-level]");
    const resultSummary = root.querySelector("[data-result-summary]");
    const resultThermometerLabel = root.querySelector("[data-result-thermometer-label]");
    const resultDetail = root.querySelector("[data-result-detail]");

    const getCheckedAnswers = () => Array.from(root.querySelectorAll("input[data-answer]:checked"));

    const getScore = () => {
      const checkedAnswers = getCheckedAnswers();
      return {
        answered: checkedAnswers.length,
        yes: checkedAnswers.filter((answer) => answer.value === "yes").length,
      };
    };

    const findBand = (score) => bands.find((band) => score >= band.min && score <= band.max) ?? bands[0];

    const updateProgress = () => {
      const score = getScore();
      const missing = total - score.answered;

      if (answeredCount) answeredCount.textContent = String(score.answered);
      if (progressBar) progressBar.style.width = `${(score.answered / total) * 100}%`;
      if (showResultButton) showResultButton.disabled = score.answered < total;
      if (missingText) {
        missingText.textContent =
          missing === 0 ? "Ya puedes ver tu resultado." : `Faltan ${missing} respuesta${missing === 1 ? "" : "s"}.`;
      }
      if (resultPanel) resultPanel.classList.add("hidden");
    };

    const showResult = () => {
      const score = getScore();

      if (score.answered < total) return;

      const band = findBand(score.yes);
      const thermometerPercent = total > 0 ? (score.yes / total) * 100 : 0;
      const fillPercent = Math.max(7, thermometerPercent);

      if (thermometerFill) {
        thermometerFill.style.height = `${fillPercent}%`;
        thermometerFill.style.background = band.accent;
      }
      if (thermometerBulb) thermometerBulb.style.background = band.accent;
      if (thermometerMarker) {
        thermometerMarker.style.bottom = `${thermometerPercent}%`;
        thermometerMarker.style.background = band.accent;
      }
      if (resultContent) {
        resultContent.style.background = `linear-gradient(135deg, ${band.soft} 0%, #ffffff 72%)`;
        resultContent.style.borderLeft = `6px solid ${band.accent}`;
      }
      if (resultLevel) {
        resultLevel.textContent = band.level;
        resultLevel.style.borderColor = band.accent;
        resultLevel.style.background = band.soft;
        resultLevel.style.color = band.color;
      }
      if (resultSummary) {
        resultSummary.textContent = band.summary;
        resultSummary.style.color = band.color;
      }
      if (resultThermometerLabel) {
        resultThermometerLabel.textContent = band.thermometerLabel;
        resultThermometerLabel.style.color = band.color;
      }
      if (resultDetail) resultDetail.textContent = band.detail;
      if (resultPanel) {
        resultPanel.classList.remove("hidden");
        resultPanel.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    };

    form?.addEventListener("change", updateProgress);
    showResultButton?.addEventListener("click", showResult);
    resetButton?.addEventListener("click", () => {
      form?.reset();
      updateProgress();
    });

    updateProgress();
  }
</script>
