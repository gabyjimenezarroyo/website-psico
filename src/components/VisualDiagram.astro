---
const concepts = [
  {
    id: "abuso",
    number: "01",
    title: "Abuso emocional",
    short: "Desgaste de confianza",
    text: "La relacion empieza a erosionar tu autonomia, tu seguridad interna y tu capacidad de decidir desde la calma.",
    signal: "Sentis que cualquier decision puede traer reclamo, castigo o distancia.",
    y: 23,
    anchor: "left",
    tone: "#D46A5D",
  },
  {
    id: "gaslighting",
    number: "02",
    title: "Gaslighting",
    short: "Duda instalada",
    text: "Mensajes repetidos te hacen cuestionar tu memoria, tu percepcion y hasta tu derecho a sentirte herida.",
    signal: "Terminas explicando una y otra vez lo que viste, escuchaste o sentiste.",
    y: 18,
    anchor: "right-top",
    tone: "#8067B7",
  },
  {
    id: "trauma",
    number: "03",
    title: "Trauma bonding",
    short: "Alivio que engancha",
    text: "Los ciclos de dano, disculpa y alivio crean una union intensa que vuelve dificil soltar aunque haya dolor.",
    signal: "Despues de una crisis, una pequena muestra de afecto se siente como esperanza.",
    y: 69,
    anchor: "right",
    tone: "#D79A34",
  },
  {
    id: "manipulacion",
    number: "04",
    title: "Manipulacion",
    short: "Control indirecto",
    text: "La culpa, el silencio, la amenaza o el afecto condicionado se usan para mover tus limites.",
    signal: "Cambias tu conducta para evitar enojo, frialdad o reproches.",
    x: 42,
    y: 84,
    anchor: "center",
    tone: "#4B8B7F",
  },
  {
    id: "codependencia",
    number: "05",
    title: "Codependencia",
    short: "Perderte por sostener",
    text: "Priorizar la relacion por encima de tus necesidades vuelve borrosos tus limites y tu sentido de identidad.",
    signal: "Te cuesta elegirte si eso decepciona o incomoda a la otra persona.",
    y: 68,
    anchor: "left",
    tone: "#4D90B7",
  },
];
---

<div class="emotional-map">
  {concepts.map((concept, index) => (
    <input class="map-choice" type="radio" name="emotional-map" id={`map-${concept.id}`} checked={index === 0} />
  ))}

  <div class="map-canvas" aria-label="Mapa interactivo del ciclo emocional">
    <svg class="map-lines" viewBox="0 0 100 100" aria-hidden="true">
      <path class="route route-main" d="M18 23 C38 4 58 6 76 18 S96 48 82 69 S58 95 42 84 S8 78 16 62 S2 40 18 23" />
      <path class="route route-soft" d="M18 23 C32 42 66 42 82 69" />
      <path class="route route-soft" d="M76 18 C50 38 35 54 16 62" />
      <path class="route route-soft" d="M42 84 C43 58 54 39 76 18" />
    </svg>

    <div class="map-core">
      <span>Mapa emocional</span>
      <strong>Del ciclo a la claridad</strong>
    </div>

    {concepts.map((concept) => (
      <label
        class={`map-node map-node-${concept.anchor}`}
        for={`map-${concept.id}`}
        style={`--x:${concept.x ?? 50}%; --y:${concept.y}%; --tone:${concept.tone};`}
      >
        <span class="node-number">{concept.number}</span>
        <span class="node-copy">
          <strong>{concept.title}</strong>
          <small>{concept.short}</small>
        </span>
      </label>
    ))}
  </div>

  <div class="map-details">
    <p class="eyebrow">Lectura del mapa</p>
    {concepts.map((concept) => (
      <article class="map-card" data-card={concept.id}>
        <span style={`--tone:${concept.tone};`}>{concept.number}</span>
        <h3>{concept.title}</h3>
        <p>{concept.text}</p>
        <div>
          <strong>Senal frecuente</strong>
          <p>{concept.signal}</p>
        </div>
      </article>
    ))}
  </div>
</div>

<style>
  .emotional-map {
    position: relative;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1.25fr) minmax(20rem, 0.75fr);
    align-items: stretch;
  }

  .map-choice {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .map-canvas {
    position: relative;
    min-height: clamp(32rem, 48vw, 40rem);
    overflow: hidden;
    border-radius: 2rem;
    border: 1px solid rgba(47, 109, 106, 0.12);
    background:
      radial-gradient(circle at 50% 48%, rgba(255, 255, 255, 0.92) 0 9rem, transparent 9.1rem),
      radial-gradient(circle at 18% 23%, rgba(212, 106, 93, 0.2), transparent 13rem),
      radial-gradient(circle at 76% 18%, rgba(128, 103, 183, 0.18), transparent 12rem),
      radial-gradient(circle at 82% 69%, rgba(215, 154, 52, 0.2), transparent 13rem),
      linear-gradient(135deg, #285f5c 0%, #3f7772 48%, #eef7f5 100%);
    box-shadow: 0 26px 80px rgba(47, 109, 106, 0.17);
  }

  .map-lines {
    position: absolute;
    inset: 6%;
    inline-size: 88%;
    block-size: 88%;
    filter: drop-shadow(0 16px 26px rgba(26, 26, 26, 0.14));
  }

  .route {
    fill: none;
    stroke-linecap: round;
  }

  .route-main {
    stroke: rgba(255, 255, 255, 0.78);
    stroke-width: 1.4;
    stroke-dasharray: 1 4;
  }

  .route-soft {
    stroke: rgba(141, 224, 216, 0.42);
    stroke-width: 0.75;
  }

  .map-core {
    position: absolute;
    inset: 50% auto auto 50%;
    display: grid;
    inline-size: min(17rem, 48%);
    min-height: 10.5rem;
    place-items: center;
    padding: 1.5rem;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    text-align: center;
    box-shadow: 0 24px 70px rgba(26, 26, 26, 0.13);
    backdrop-filter: blur(18px);
  }

  .map-core span {
    color: #2f6d6a;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .map-core strong {
    max-width: 11rem;
    font-family: "Playfair Display", serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 0.98;
    color: #1a1a1a;
  }

  .map-node {
    position: absolute;
    top: var(--y);
    z-index: 2;
    display: flex;
    inline-size: min(18.25rem, calc(100% - 2.5rem));
    cursor: pointer;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 0.95rem 0.75rem 0.75rem;
    transform: translateY(-50%);
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 16px 34px rgba(26, 26, 26, 0.13);
    color: #1a1a1a;
    transition:
      transform 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
    backdrop-filter: blur(14px);
  }

  .map-node:hover,
  .map-node:focus-visible {
    transform: translateY(-50%) scale(1.035);
    background: #ffffff;
    box-shadow: 0 20px 45px rgba(26, 26, 26, 0.18);
    outline: none;
  }

  .map-node-left {
    left: 1.25rem;
  }

  .map-node-right,
  .map-node-right-top {
    right: 1.25rem;
  }

  .map-node-right-top {
    right: 7%;
  }

  .map-node-center {
    left: var(--x);
    transform: translate(-50%, -50%);
  }

  .map-node-center:hover,
  .map-node-center:focus-visible {
    transform: translate(-50%, -50%) scale(1.035);
  }

  .node-number {
    display: grid;
    flex: 0 0 auto;
    inline-size: 2.55rem;
    block-size: 2.55rem;
    place-items: center;
    border-radius: 999px;
    background: var(--tone);
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .node-copy {
    display: grid;
    min-width: 0;
    gap: 0.12rem;
  }

  .node-copy strong {
    font-family: "Playfair Display", serif;
    font-size: clamp(1.08rem, 1.55vw, 1.34rem);
    font-weight: 700;
    line-height: 1;
  }

  .node-copy small {
    color: rgba(26, 26, 26, 0.62);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .map-details {
    position: relative;
    min-height: clamp(32rem, 48vw, 40rem);
    overflow: hidden;
    border-radius: 2rem;
    border: 1px solid rgba(47, 109, 106, 0.1);
    background: #ffffff;
    padding: clamp(1.5rem, 3vw, 2rem);
    box-shadow: 0 24px 70px rgba(26, 26, 26, 0.08);
  }

  .map-card {
    position: absolute;
    inset: 5.25rem clamp(1.5rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    opacity: 0;
    transform: translateY(1rem);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
    pointer-events: none;
  }

  .map-card > span {
    display: grid;
    inline-size: 3rem;
    block-size: 3rem;
    place-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--tone) 16%, white);
    color: var(--tone);
    font-weight: 800;
  }

  .map-card h3 {
    margin: 1.35rem 0 0;
    font-family: "Playfair Display", serif;
    font-size: clamp(2.25rem, 3.15vw, 3.55rem);
    line-height: 1;
    color: #1a1a1a;
    overflow-wrap: anywhere;
  }

  .map-card > p {
    margin: 1.25rem 0 0;
    color: rgba(26, 26, 26, 0.7);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .map-card div {
    margin-top: 2rem;
    border-left: 4px solid var(--tone);
    padding-left: 1rem;
  }

  .map-card div strong {
    color: #2f6d6a;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .map-card div p {
    margin: 0.4rem 0 0;
    color: rgba(26, 26, 26, 0.74);
    line-height: 1.65;
  }

  #map-abuso:checked ~ .map-canvas label[for="map-abuso"],
  #map-gaslighting:checked ~ .map-canvas label[for="map-gaslighting"],
  #map-trauma:checked ~ .map-canvas label[for="map-trauma"],
  #map-manipulacion:checked ~ .map-canvas label[for="map-manipulacion"],
  #map-codependencia:checked ~ .map-canvas label[for="map-codependencia"] {
    background: #ffffff;
    box-shadow:
      0 0 0 0.35rem color-mix(in srgb, var(--tone) 22%, transparent),
      0 22px 50px rgba(26, 26, 26, 0.2);
    transform: translateY(-50%) scale(1.035);
  }

  #map-manipulacion:checked ~ .map-canvas label[for="map-manipulacion"] {
    transform: translate(-50%, -50%) scale(1.035);
  }

  #map-abuso:checked ~ .map-details [data-card="abuso"],
  #map-gaslighting:checked ~ .map-details [data-card="gaslighting"],
  #map-trauma:checked ~ .map-details [data-card="trauma"],
  #map-manipulacion:checked ~ .map-details [data-card="manipulacion"],
  #map-codependencia:checked ~ .map-details [data-card="codependencia"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (max-width: 900px) {
    .emotional-map {
      grid-template-columns: 1fr;
    }

    .map-canvas,
    .map-details {
      min-height: 34rem;
    }
  }

  @media (max-width: 640px) {
    .map-canvas {
      min-height: 42rem;
    }

    .map-core {
      inline-size: 12.5rem;
      min-height: 8rem;
    }

    .map-node {
      inline-size: min(14.5rem, calc(100% - 1.5rem));
      padding-right: 0.8rem;
    }

    .map-node-left {
      left: 0.75rem;
    }

    .map-node-right,
    .map-node-right-top {
      right: 0.75rem;
    }

    .node-copy strong {
      font-size: 1rem;
    }

    .node-copy small {
      display: none;
    }

    .map-details {
      min-height: 32rem;
    }
  }
</style>
